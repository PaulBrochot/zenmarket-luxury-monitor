# ─── Configuration ZenMarket Luxury Monitor ─────────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs.

# 1. URL du Webhook Discord
#    Obtenir sur : Serveur Discord → Paramètres → Intégrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 2. API de taux de change (Frankfurter, gratuit, sans clé)
RATE_API_BASE=https://api.frankfurter.app

# 3. Chemin de la base SQLite
DB_PATH=data/seen_items.db

# 4. Intervalle entre cycles (secondes)
CHECK_MIN=120
CHECK_MAX=300

# 5. Nombre max de pages à scraper par requête
MAX_PAGES=3
